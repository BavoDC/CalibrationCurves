n <- nrow(trainDataSurvival)
status2 <- sample(0:2, n, replace = TRUE, prob = c(0.3, 0.5, 0.2))
trainDataSurvival$status2 <- status2
testDataSurvival$status2 <- sample(0:2, nrow(testDataSurvival), replace = TRUE,
